# Alibaba Cloud Model Studio is used for grounded GraphRAG answers and tool planning.
# Copy this file to backend/.env and fill a newly generated key. Never commit backend/.env.
LLM_ENABLED=false
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=
LLM_MODEL=qwen-plus
LLM_TIMEOUT_SECONDS=60

# Production semantic retrieval (SiliconFlow Qwen embedding)
QDRANT_ENABLED=true
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=tcm_documents_v5
EMBEDDING_PROVIDER=siliconflow
EMBEDDING_MODEL=Qwen/Qwen3-VL-Embedding-8B
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BATCH_SIZE=10
EMBEDDING_CONCURRENCY=4
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# Leave empty to reuse LLM_API_KEY.
EMBEDDING_API_KEY=

# Task 2 graph management. Memory is complete and requires no MySQL/Neo4j.
STORE_BACKEND=memory
DATA_FILE=./data/store.json
JWT_SECRET=
JWT_EXPIRE_HOURS=24
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Fill these only when STORE_BACKEND=mysql, neo4j, or hybrid.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=tcm
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Optional external Milvus. Enable only after the service and collection exist.
MILVUS_ENABLED=false
MILVUS_URI=http://127.0.0.1:19530
MILVUS_COLLECTION=tcm_rag_chunks
