# DeepSeek is used for grounded GraphRAG answers, case explanations and tool planning.
# Copy this file to backend/.env and fill a newly generated key. Never commit backend/.env.
LLM_ENABLED=false
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash
LLM_TIMEOUT_SECONDS=60

# Optional third-party graph source. Keep false to use only the project's
# native entities/relations and to exclude the SymMap-derived vector document.
ENABLE_SYMMAP_DATA=false
